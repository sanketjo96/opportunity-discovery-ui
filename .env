# API origin without a trailing slash. Axios uses this as baseURL; requests use paths like /api/opportunities.
# Examples: http://127.0.0.1:3000  or  https://api.example.com
# Leave empty to use the current page origin (typical with Vite dev proxy in vite.config.ts).
PROD_API_BASE_URL=
DEV_API_BASE_URL=http://127.0.0.1:3000
